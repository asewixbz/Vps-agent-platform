APP_NAME=vps-agent-control-plane
APP_DB_PATH=/data/app.db
APP_WORK_DIR=/data/work
APP_ARTIFACT_DIR=/data/artifacts
APP_REDIS_URL=redis://redis:6379/0
APP_TASK_QUEUE_NAME=agent_tasks
APP_WORKER_POLL_SECONDS=5
APP_WORKER_ONCE=false
APP_ALLOWED_SHELL_COMMANDS=echo,ls,pwd,cat,grep,python
APP_DEFAULT_TIMEOUT_SECONDS=60
APP_REQUIRE_APPROVAL_FOR_DRAFT=true
APP_BROWSER_RUNNER_ENABLED=false
APP_MODEL_RUNNER_ENABLED=false
