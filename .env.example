APP_NAME=vps-agent-control-plane
APP_DB_PATH=/data/app.db
APP_WORK_DIR=/data/work
APP_ARTIFACT_DIR=/data/artifacts
APP_REDIS_URL=redis://redis:6379/0
APP_TASK_QUEUE_NAME=agent_tasks
APP_WORKER_POLL_SECONDS=5
APP_WORKER_ONCE=false
APP_ALLOWED_SHELL_COMMANDS=echo,ls,pwd,cat,grep,python
APP_DEFAULT_TIMEOUT_SECONDS=60
APP_TASK_TIMEOUT_HARD_LIMIT_SECONDS=300
APP_RUNTIME_MAX_STEPS_HARD_LIMIT=10
APP_TOOL_POLICY_OVERRIDES_JSON={}
APP_REQUIRE_APPROVAL_FOR_DRAFT=true
APP_BROWSER_RUNNER_ENABLED=false
APP_MODEL_RUNNER_ENABLED=false
APP_MODEL_ADAPTER_NAME=unconfigured
APP_MODEL_DEFAULT_ALIAS=general
APP_MODEL_REQUEST_TIMEOUT_SECONDS=120
APP_MODEL_ADAPTER_OPTIONS_JSON={}
APP_TASK_SANDBOX_MODE=auto
APP_TASK_SANDBOX_ALLOW_NETWORK=false
APP_TASK_SANDBOX_MEMORY_MB=256
APP_TASK_SANDBOX_MAX_PROCESSES=8
APP_TASK_SANDBOX_MAX_OPEN_FILES=64
APP_TASK_SANDBOX_MAX_FILE_SIZE_MB=16
